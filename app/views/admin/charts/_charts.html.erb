<!-- Chart Filter Controls -->
<div class="d-flex justify-content-center align-items-center gap-4">
  <%= link_to admin_charts_filter_path(year: year.to_i - 1), data: { turbo_stream: true } do %>
    <i class="bi bi-arrow-left-circle-fill fs-4 chart-control"></i>
  <% end %>

  <span class="dongle fs-1 pt-1"><%= year %></span>

  <%= link_to admin_charts_filter_path(year: year.to_i + 1), data: { turbo_stream: true } do %>
    <i class="bi bi-arrow-right-circle-fill fs-4 chart-control"></i>
  <% end %>
</div>
<!-- Chart Graphics -->
<div class="row justify-content-center">
  <div class="col col-sm-8 col-lg-5 pb-4">
    <%= column_chart admin_charts_orders_path(year: year), title: "Revenue", height: "450px" %>
  </div>
  <div class="col col-sm-8 col-lg-5">
    <%= pie_chart admin_charts_products_path(year: year), title: "Popularity", height: "450px" %>
  </div>
  <div class="col col-sm-8 col-xl-6 pt-4">
    <%= line_chart admin_charts_monthly_path, title: "30 days", height: "450px" %>
  </div>
</div>
