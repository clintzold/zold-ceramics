
<h1 class="text-center p-3 p-md-0">Orders</h1>

<!-- Filter Form -->
<%=
  form_with url: admin_filter_orders_path, method: :get, data: {turbo_stream: true, controller: "filter", action: "change->filter#filter"} do |form| %>
  <div class="container-fluid d-flex justify-content-center py-3">
    <div>
      <%= form.label :order_type, "Order Type" %>
      <%= form.select :order_type,
        options_for_select([['All', 1], ['Delivery', 2], ['Pickup', 3]]),
        class: "form-select form-control"
      %>
    </div>
  </div>
  <ul class="list-unstyled d-flex justify-content-center gap-4 me-3">
    <% @statuses.each do |status| %>
      <li>
        <%= check_box_tag "filtered_status[]",
          status,
          params[:filtered_status]&.include?(status),
          id: status
        %>
        <%= label_tag status, status.capitalize %>
      </li>
    <% end %>
  </ul>
<% end %>

<!-- Filtered Results -->
<%= turbo_frame_tag "filtered_results" do %>
    <%= render partial: "results", locals: { orders: @orders } %>
<% end %>
