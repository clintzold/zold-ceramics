<div class="card bg-info pt-2 fade-card shadow position-relative">
  <!-- Exit button -->
  <%= link_to admin_pickup_path(pickup) do %>
    <i class="bi bi-arrow-left-square text-white exit-button"></i>
  <% end %>
  <h2 class="card-title text-center dongle text-white">Order Preview</h2>
  <!-- Mark order as delivered button -->
  <div class="delivered-status text-white fs-3" >
    <%= turbo_frame_tag "order_status" do %>
      <%= render "admin/orders/status", order: order %>
    <% end %>
  </div>

  <p class="text-center text-white m-0"><%= order.name.titleize %></p>
  <div class="card-body p-2">
    <ul class="list-group modal-scroll-section list-group-flush">
      <% order.order_items.each do |item| %>
        <li class="list-group-item">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <%= image_tag item.product.main_image.variant(:thumb), class: "mx-auto"%>
            </div>
            <div class="dongle fs-4 pt-2 mt-1">
              <%= item.product.title %>
            </div>
            <div class="borel opacity-75">
              X <%= item.quantity %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
    <div class="d-flex justify-content-center pt-2">
      <% opacity = "opacity-0" if order.status == "delivered" %>
      <%= link_to "Mark Received",
        admin_order_delivered_path(order),
        class: "btn btn-sm btn-outline-light ",
        data: { turbo_stream: true }
      %>
    </div>
  </div>
</div>
