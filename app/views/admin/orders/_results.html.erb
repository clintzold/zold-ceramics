<div class="scroll-list wide-list" id="filtered_results">
  <table class="table text-nowrap" id="index-table">
    <thead>
      <tr>
        <th >#</th>
        <th>Name</th>
        <th>Email</th>
        <th>Date</th>
        <th>Status</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      <% if orders.any? %>
        <% orders.order(created_at: :desc).each do |order| %>
          <tr class="small">
            <th><%= order.id %></th>
            <td><%= link_to "#{order.name.titleize}", admin_order_path(order.id), data: { turbo_frame: "_top" } %></td>
            <td><%= order.email %></td>
            <td><%= order.created_at.strftime("%B %d, %y") %></td>
            <td><%= order.status %></td>
            <td><%= number_to_currency(order.total) %></td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
