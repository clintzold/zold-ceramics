<div class="card bg-secondary modal-card pt-2 fade-card shadow position-relative">
  <i class="bi bi-x-square text-white modal-exit-button" data-action="click->modal#hide"></i>
  <h3 class="card-title text-center text-white">Order Details</h3>
  <p class="text-center text-white m-0"><%= order.name.titleize %></p>
  <div class="card-body">
    <ul class="list-group modal-scroll-section list-group-flush">
      <% order.order_items.each do |item| %>
        <li class="list-group-item">
          <%= image_tag item.product.main_image.variant(:thumb), class: "mx-auto"%>
          <div class="d-flex justify-content-between">
            <div>
              <%= item.product.title %>
            </div>
            <div>
              X <%= item.quantity %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
</div>
