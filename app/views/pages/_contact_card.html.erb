<!-- Contact card and teaser info -->
<div class="container-fluid" data-scroll-reveal-target="section">
  <div class="row justify-content-center reveal-item">

    <!-- Card -->
    <div class="card image-link-card border-0 rounded-0 shadow-lg col col-xl-10 col-xxl-8 p-0">
          <!-- Card Image -->
      <%= image_tag "cream-mugs-resize.webp", class: "card-image" %>

      <!-- Card Overlay -->
      <div class="card-img-overlay d-flex text-center flex-column align-items-center justify-content-center p-5-sm text-light">
        <div class="d-none slide-up" data-scroll-reveal-target="text">
          <h1 class="card-title display-1 home-card-title" style="text-shadow: 1px 0px 5px black">Contact us</h1>
          <div class="d-flex justify-content-center p-2">
            <%= link_to "Contact Form", new_contact_form_path, data: { turbo_stream: true }, class: "btn btn-outline-light btn-lg border-2 shadow-lg" %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
