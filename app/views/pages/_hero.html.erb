<!-- Hero Photo -->
<div class="container-fluid">
  <div class="row justify-content-center">
    <div class="col p-0">
      <div class="card hero-image-container bg-transparent border-0 d-flex">
        <div class="card-img-overlay heroOverlay d-flex flex-column justify-content-center gap-5 align-items-center p-lg-5">
          <div class="heroText">
            <p class="hero-title text-center text-light">
              Zold Ceramics
            </p>
            <p class="card-text text-center text-light h4" style="text-shadow: 1px 0px 10px black;">
              Timeless, handcrafted pottery.
            </p>
          </div>
          <%= button_to "Shop Now", shop_path, method: :get, class: "btn btn-lg border-2 btn-outline-light mt-md-3 shadow-lg" %>
        </div>
      </div>
    </div>
  </div>
</div>
