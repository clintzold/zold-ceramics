<!-- About card and teaser info -->
<div class="container-fluid" data-scroll-reveal-target="section">
  <div class="row justify-content-center reveal-item">

    <!-- Card -->
    <div class="card image-link-card border-0 rounded-0 shadow-lg col col-lg-11 col-xl-9 col-xxl-8 p-0">
          <!-- Card Image -->
      <%= image_tag "about-card-resize.webp", class: "card-image" %>

      <!-- Card Overlay -->
      <div class="card-img-overlay d-flex flex-column p-5 text-center align-items-center justify-content-center text-light">
        <div class="d-none slide-up" data-scroll-reveal-target="text">
          <h1 class="card-title home-card-title display-1" style="text-shadow: 1px 0px 5px black;">My Story...</h1>
          <div class="d-flex justify-content-center p-2">
            <%= link_to "Read more", about_path, data: { turbo_stream: true }, class: "btn btn-outline-light btn-lg border-2" %>
          </div>
        </div>
      </div>
      <!-- End Card Overlay -->

    </div>
    <!-- End Card -->

  </div>
</div>
