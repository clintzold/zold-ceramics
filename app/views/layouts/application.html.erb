<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Zold Ceramics" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Zold Ceramics">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= favicon_link_tag 'favicon-1-c1.png', type: 'image/png' %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <!-- Preload main font to avoid seeing fallback -->
    <%= preload_link_tag "GreatVibes-Regular.woff2", as: "font", type: "font/woff2", crossorigin: "anonymous" %>
    <%= preload_link_tag "Dongle-Regular.woff2", as: "font", type: "font/woff2", crossorigin: "anonymous" %>
    <%= preload_link_tag "Dongle-Bold.woff2", as: "font", type: "font/woff2", crossorigin: "anonymous" %>
    <%= preload_link_tag "Dongle-Light.woff2", as: "font", type: "font/woff2", crossorigin: "anonymous" %>
    <%= preload_link_tag "Borel-Regular.woff2", as: "font", type: "font/woff2", crossorigin: "anonymous" %>
    <!-- Preload Hero and other critical images -->
    <%= preload_link_tag "home-hero.webp",
      as: "image", type: "image/webp",
      imagesrcset: "#{image_path('home-hero-small.webp')} 535w, #{image_path('home-hero-medium.webp')} 1070w",
      imagesizes: "100vw",
      fetchpriority: "high" %>
    <%= preload_link_tag "shop-hero.webp",
      as: "image", type: "image/webp",
      imagesrcset: "#{image_path('shop-hero-small.webp')} 512w, #{image_path('shop-hero-medium.webp')} 1024w, #{image_path('shop-hero-large.webp')} 2048w",
      imagesizes: "100vw",
      fetchpriority: "high" %>
    <%# Allow page specific javascripts to be loaded in the head as needed %>
    <%= yield(:page_scripts) %>
  </head>

  <body class="d-flex flex-column justify-content-between min-vh-100 bg-light">  
      <header>
        <% if controller.controller_name == "admin" %>
          <%= render "shared/admin_nav" %>
        <% else %>
          <%= render "shared/main_nav" %>
        <% end %>
      </header>

      <main>
        <!-- Cart Summary Collapse and Button -->
        <%= render "carts/cart_summary", show: "hidden", cart: @cart %>
        <%= render "layouts/cart_button", animation_type: nil %>
        <!-- Page Content -->
        <%= yield %>
      </main>

      <div class="container">
      <footer class=" d-flex flex-wrap justify-content-between align-items-center py-1 my-1 border-top">
        <div class="col-md-4 d-flex align-items-center">
          <a href="/" class="text-body-secondary text-decoration-none lh-1" aria-label="Bootstrap">
            <i class="bi bi-cup-hot-fill h3 mb-0"></i>
          </a>
        </div>
        <span class="text-body-secondary ms-sm-0 ms-2">© 2025 Zold Ceramics</span>
        <ul class="nav col-md-4 justify-content-end list-unstyled d-flex">
          <li class="">
            <a class="text-body-secondary fs-5" href="#" aria-label="Instagram">
              <i class="bi bi-instagram"></i>
            </a>
          </li>
          <li class="ms-3">
            <a class="text-body-secondary fs-5" href="#" aria-label="Facebook">
              <i class="bi bi-facebook"></i>
            </a>
          </li>
        </ul>
      </footer>
    </div>
  </body>
</html>
