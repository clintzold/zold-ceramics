<div class="overflow-scroll bg-white" id="filtered_results">
  <table class="table" id="index-table">
    <thead>
      <tr>
        <th >#</th>
        <th>View</th>
        <th>Status</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      <% if @orders.any? %>
        <%@orders.order(created_at: :desc).each do |order| %>
          <tr>
            <th><%= order.id %></th>
            <td><%= link_to "View Order", order_path(order.id), data: { turbo_stream: true } %></td>
            <td><%= order.status %></td>
            <td><%= number_to_currency(order.total) %></td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
